      ],
      "source": [
        "# أول كود بايثون لي في رحلة البحث العلمي\n",
        "print(\"مرحباً! أنا أتعلم Python من أجل Agentic AI\")\n",
        "\n",
        "name = \"أنا باحث\"\n",
        "print(f\"أهلاً {name}، سنبدأ رحلة رائعة!\")\n",
        "\n",
        "# قائمة بأهدافي\n",
        "goals = [\"تعلم Python\", \"فهم Agentic AI\", \"كتابة أول بحث\"]\n",
        "for g in goals:\n",
        "    print(f\"✅ {g}\")"
      ]
    },
